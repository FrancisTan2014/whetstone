# Merriam-Webster Dictionary API keys (free, non-commercial use). Get keys at
# https://dictionaryapi.com/. Copy this file to .env and paste your own keys.
# The app works with NO keys set (it falls back to the free dictionaryapi.dev).
MERRIAM_WEBSTER_LEARNERS_KEY=your-learners-key
MERRIAM_WEBSTER_COLLEGIATE_KEY=your-collegiate-key
