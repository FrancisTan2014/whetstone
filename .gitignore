# .NET / MAUI
bin/
obj/
*.user
*.suo
.vs/

# Local SQLite (when implementation starts)
*.db
*.db-shm
*.db-wal

# IDE
.idea/
.vscode/

# OS
.DS_Store
Thumbs.db

# Personal notes (in case dev seeds get committed by accident — real notes belong in a separate vault)
/notes/
/seeds/local-*.md

# Local agent run logs
.agent-logs/
*.log

# Node / TypeScript
node_modules/
dist/
coverage/
*.tsbuildinfo
pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local server data (retained source files / local database)
.data/

# Screenshot harness output (manual `pnpm screenshots`; never committed)
artifacts/

# Playwright E2E smoke output (boot artifacts + test results; never committed)
e2e/.tmp/
playwright-report/
test-results/

# Lighthouse CI report output (generated by the advisory `pnpm lighthouse` / CI job)
.lighthouseci/

# Stryker mutation-testing output (advisory `pnpm mutation` / nightly CI job)
reports/mutation/
.stryker-tmp/

# Environment files
.env
.env.*
!.env.example
