{
  "name": "@whetstone/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b tsconfig.json && vite build",
    "dev": "tsc -b tsconfig.json && vite --host 127.0.0.1",
    "preview": "vite preview --host 127.0.0.1",
    "smoke": "tsc -b tsconfig.json && node dev-smoke.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.5",
    "@fontsource-variable/source-serif-4": "^5.2.5",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@tiptap/static-renderer": "^3.27.1",
    "@whetstone/contracts": "workspace:*",
    "@whetstone/document": "workspace:*",
    "@whetstone/domain": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "framer-motion": "^12.23.12",
    "hast-util-sanitize": "^5.0.2",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "mdast-util-to-hast": "^13.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.6.2",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "0.2.3",
    "@tailwindcss/vite": "^4.1.13",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "1.0.0",
    "tailwindcss": "^4.1.13",
    "vite": "^8.0.16"
  }
}
