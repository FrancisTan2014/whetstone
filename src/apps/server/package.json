{
  "name": "@whetstone/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b tsconfig.json && node -e \"const fs=require('node:fs');fs.cpSync('src/db/migrations','dist/db/migrations',{recursive:true});fs.cpSync('src/lookup/data','dist/lookup/data',{recursive:true});fs.copyFileSync('src/files/pdf_to_markdown.py','dist/files/pdf_to_markdown.py')\"",
    "dev": "tsx watch --env-file-if-exists=../../../.env dev-server.mjs",
    "mcp": "node --env-file-if-exists=../../../.env dist/mcp/main.js",
    "start": "node --env-file-if-exists=../../../.env dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@fastify/static": "^8.3.0",
    "@lingo-reader/epub-parser": "^0.4.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@whetstone/contracts": "workspace:*",
    "@whetstone/document": "workspace:*",
    "@whetstone/domain": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fflate": "^0.8.3",
    "jsdom": "^26.0.0",
    "prosemirror-model": "^1.25.9",
    "wordpos": "^2.1.0"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7"
  }
}
