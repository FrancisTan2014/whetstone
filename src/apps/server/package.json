{
  "name": "@whetstone/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b tsconfig.json && node -e \"require('node:fs').cpSync('src/db/migrations','dist/db/migrations',{recursive:true})\"",
    "start": "node --env-file-if-exists=../../../.env dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@lingo-reader/epub-parser": "^0.4.6",
    "@whetstone/contracts": "workspace:*",
    "@whetstone/domain": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5"
  }
}
