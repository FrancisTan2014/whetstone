@echo off
setlocal
cd /d "%~dp0.."
if not exist ".agent-locks" exit /b 0

powershell -NoProfile -Command "$lock = '.agent-locks\worker.lock'; if (-not (Test-Path $lock)) { exit 0 }; $pidPath = Join-Path $lock 'pid.txt'; $startedPath = Join-Path $lock 'startedAt.txt'; $stale = $true; $reason = 'missing_pid'; $started = $null; if (Test-Path $startedPath) { try { $started = [datetime](Get-Content -Raw $startedPath) } catch { $reason = 'bad_startedAt' } }; if (Test-Path $pidPath) { try { $ownerPid = [int](Get-Content -Raw $pidPath); $proc = Get-Process -Id $ownerPid -ErrorAction SilentlyContinue; if ($proc -and $proc.ProcessName -in @('copilot','node')) { $stale = $false; $reason = 'active'; if ($started -and $proc.StartTime -gt $started.AddMinutes(1)) { $stale = $true; $reason = 'pid_reused' }; if ($started -and ((Get-Date) - $started).TotalHours -gt 12) { $stale = $true; $reason = 'older_than_12h' } } else { $reason = 'pid_not_running' } } catch { $reason = 'bad_pid' } }; if ($stale) { Remove-Item $lock -Recurse -Force; Write-Host ('Removed stale whetstone worker lock: ' + $reason); $statusPath = '.agent-status.local.json'; if (Test-Path $statusPath) { $status = Get-Content -Raw $statusPath | ConvertFrom-Json; if ($status.PSObject.Properties.Name -notcontains 'coordinator') { $status | Add-Member -NotePropertyName coordinator -NotePropertyValue ([pscustomobject]@{}) }; if ($status.coordinator.PSObject.Properties.Name -notcontains 'lastRemovedWorkerLockReason') { $status.coordinator | Add-Member -NotePropertyName lastRemovedWorkerLockReason -NotePropertyValue $null }; $status.coordinator.lastRemovedWorkerLockReason = $reason; $status.updatedAt = (Get-Date).ToString('o'); $status | ConvertTo-Json -Depth 12 | Set-Content $statusPath } }"
